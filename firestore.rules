rules_version = '2';
service cloud.firestore {
 match /databases/{database}/documents {
   // Zero-Trust Security Configuration:
   // Directly deny all direct client-side read and write queries.
   // All interaction with database collections must securely go through
   // the verified, role-checked Node.js backend server API endpoints only.
   match /{document=**} {
     allow read, write: if false;
   }
 }
}
